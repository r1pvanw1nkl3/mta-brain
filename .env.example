ETL_DB_PASSWORD=etl_password

# Application Database User (read-only preferred for API)
APP_DB_USER=app_user
APP_DB_PASSWORD=app_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
